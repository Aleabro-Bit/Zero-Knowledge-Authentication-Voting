def main(
    private u32 birth_year,
    public u32 current_year,
    public field user_address
	) -> bool {
        u32 age = current_year - birth_year;
        assert(age >= 18);

        assert(birth_year <= current_year);
        assert(birth_year >= 1900);

        field verify_address = user_address * 1;
        assert(verify_address == user_address);

        return true;
}
